{
  "name": "react-native-monorepo",
  "version": "1.0.0",
  "description": "Turborepo + Expo + HeroUI Native monorepo template with npm workspaces, Uniwind, and Reanimated.",
  "private": true,
  "homepage": "https://github.com/stackra-inc/react-native-monorepo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackra-inc/react-native-monorepo.git"
  },
  "bugs": {
    "url": "https://github.com/stackra-inc/react-native-monorepo/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://stackra.com"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter='./packages/*'",
    "build:apps": "turbo run build --filter='./apps/*'",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css,js,mjs,cjs}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,css,js,mjs,cjs}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "clean": "./scripts/cleanup.sh build",
    "clean:all": "./scripts/cleanup.sh all",
    "clean:deps": "./scripts/cleanup.sh deps",
    "clean:cache": "./scripts/cleanup.sh cache",
    "reset": "pnpm clean:all && pnpm install",
    "prepare": "husky",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "release": "turbo run build --filter='./packages/*' && changeset publish",
    "validate": "pnpm lint && pnpm check-types && pnpm build",
    "graph": "turbo run build --graph=dependency-graph.html",
    "audit": "npm audit",
    "make:package": "./scripts/cli/create-package.sh",
    "sync:configs": "./scripts/cli/cli.sh",
    "update:deps": "npx npm-check-updates -u --peer --dep dev,prod,peer --root --workspaces",
    "update:interactive": "npx npm-check-updates -u --peer --dep dev,prod,peer --root --workspaces --interactive"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.28.0",
    "@stackra/tsup-config": "^1.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "eslint": "^9.28.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "0.7.3",
    "tsup": "^8.5.1",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@firebase/util",
      "@zowe/secrets-for-zowe-sdk",
      "esbuild",
      "protobufjs",
      "react-native-nitro-modules",
      "uniwind",
      "uniwind-pro",
      "unrs-resolver"
    ],
    "overrides": {
      "eslint": "^9.28.0",
      "@eslint/js": "^9.28.0",
      "heroui-native": "1.0.2",
      "uniwind-pro": "1.1.0",
      "react-native-nitro-modules": "0.35.5",
      "react-native-reanimated": "4.2.1",
      "react-native-worklets": "0.7.4",
      "react-native-gesture-handler": "2.30.1",
      "react-native-safe-area-context": "5.6.2",
      "react-native-svg": "15.15.3",
      "tailwind-variants": "3.2.2",
      "tailwind-merge": "3.5.0",
      "tailwindcss": "4.2.4"
    }
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "trustedDependencies": [
    "uniwind"
  ],
  "packageManager": "pnpm@10.33.2"
}
