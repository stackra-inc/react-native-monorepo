  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.28.0",
    "@stackra/tsup-config": "^1.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "eslint": "^9.28.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "0.7.3",
    "tsup": "^8.5.1",
