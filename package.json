{
  "name": "react-native-monorepo",
  "version": "0.0.0",
  "description": "Turborepo + Expo + HeroUI Native monorepo template with pnpm, Uniwind, and Reanimated.",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/stackra-inc/react-native-monorepo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackra-inc/react-native-monorepo.git"
  },
  "bugs": {
    "url": "https://github.com/stackra-inc/react-native-monorepo/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://stackra.com"
  },
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter='./packages/*'",
    "build:apps": "turbo run build --filter='./apps/*'",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css,js,mjs,cjs}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,css,js,mjs,cjs}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "clean": "./scripts/cleanup.sh build",
    "clean:all": "./scripts/cleanup.sh all",
    "clean:deps": "./scripts/cleanup.sh deps",
    "clean:cache": "./scripts/cleanup.sh cache",
    "reset": "pnpm clean:all && pnpm install",
    "prepare": "husky",
    "preinstall": "npx only-allow pnpm",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "release": "turbo run build --filter='./packages/*' && changeset publish",
    "validate": "pnpm lint && pnpm check-types && pnpm build",
    "graph": "turbo run build --graph=dependency-graph.html",
    "update:deps": "npx -y npm-check-updates -u --peer --root --workspaces",
    "update:interactive": "npx -y npm-check-updates -u --peer --root --workspaces --interactive",
    "audit": "pnpm audit --audit-level=moderate",
    "make:package": "./scripts/sync-configs/create-package.sh",
    "sync:configs": "./scripts/sync-configs/sync-configs.sh"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@nesvel/tsup-config": "^1.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "only-allow": "^1.2.2",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "0.0.0-insiders.f7d2598",
    "tsup": "^8.5.1",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "react": "19.2.0",
      "react-native": "0.83.6",
      "react-native-reanimated": "4.2.1",
      "react-native-gesture-handler": "2.30.0",
      "react-native-worklets": "0.7.4",
      "react-native-safe-area-context": "5.6.2",
      "react-native-svg": "15.15.3",
      "react-native-screens": "4.23.0",
      "react-native-keyboard-controller": "1.20.7",
      "@gorhom/bottom-sheet": "5.2.8",
      "tailwind-variants": "3.2.2",
      "tailwind-merge": "3.4.0",
      "typescript": "5.9.2"
    }
  },
  "dependencies": {
    "expo": "~55.0.17",
    "react": "19.2.0",
    "react-native": "0.83.6"
  }
}
