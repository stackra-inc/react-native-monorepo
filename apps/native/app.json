{
  "expo": {
    "name": "HeroUI Native",
    "slug": "heroui-native",
    "scheme": "herouinative",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "platforms": ["ios", "android"],

    "ios": {
      "icon": {
        "dark": "./assets/ios-icon-dark.png",
        "light": "./assets/ios-icon-light.png"
      },
      "supportsTablet": true,
      "bundleIdentifier": "com.herouinative.app",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "This app uses the camera to scan codes and capture photos.",
        "NSPhotoLibraryUsageDescription": "This app accesses your photos to let you select images.",
        "NSLocationWhenInUseUsageDescription": "This app uses your location to provide relevant content.",
        "CFBundleDevelopmentRegion": "en",
        "UIBackgroundModes": []
      },
      "associatedDomains": [],
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"],
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults"
          }
        ]
      }
    },

    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/android-adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.herouinative.android",
      "versionCode": 1,
      "permissions": ["INTERNET", "ACCESS_NETWORK_STATE", "VIBRATE"],
      "blockedPermissions": [
        "READ_PHONE_STATE",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },

    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app",
          "asyncRoutes": false
        }
      ],
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ECEDEE",
          "image": "./assets/splash-icon-light.png",
          "dark": {
            "image": "./assets/splash-icon-dark.png",
            "backgroundColor": "#151718"
          },
          "imageWidth": 200
        }
      ],
      [
        "expo-image",
        {
          "allowDownscaling": true
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    },

    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD",
      "url": "https://u.expo.dev/YOUR_PROJECT_ID"
    },

    "runtimeVersion": {
      "policy": "appVersion"
    },

    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "YOUR_PROJECT_ID"
      }
    },

    "owner": "YOUR_EXPO_OWNER"
  }
}
