{
  "name": "@repo/ui",
  "version": "0.1.0",
  "description": "Shared UI component library for the React Native monorepo. Re-exports and wraps HeroUI Native components with project-specific defaults.",
  "private": true,
  "main": "./src/index.tsx",
  "types": "./src/index.tsx",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://stackra.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackra-inc/react-native-monorepo.git",
    "directory": "packages/ui"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check-types": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "heroui-native": "^1.0.2"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-native": ">=0.83.0",
    "react-native-gesture-handler": ">=2.28.0",
    "react-native-reanimated": ">=4.1.1",
    "react-native-safe-area-context": ">=5.6.0",
    "react-native-svg": ">=15.12.1",
    "react-native-worklets": ">=0.5.1",
    "tailwind-merge": ">=3.4.0",
    "tailwind-variants": ">=3.2.2"
  },
  "peerDependenciesMeta": {
    "react-native-screens": {
      "optional": true
    },
    "@gorhom/bottom-sheet": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nesvel/typescript-config": "^1.0.4",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.14",
    "jest-expo": "^55.0.16",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "heroui",
    "react-native",
    "ui",
    "components",
    "expo",
    "mobile"
  ]
}
