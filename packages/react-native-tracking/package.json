{
  "name": "@stackra/react-native-tracking",
  "version": "1.0.0",
  "description": "Mobile engagement tracking, native SDK management, and identity sync for React Native applications",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://github.com/stackra-inc"
  },
  "keywords": [
    "react-native",
    "tracking",
    "analytics",
    "mobile",
    "meta",
    "google",
    "firebase",
    "fbsdk",
    "engagement",
    "screen-view",
    "app-open"
  ],
  "type": "module",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist node_modules/.cache",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "tslib": "^2.8.1",
    "@stackra/ts-support": "^2.5.7",
    "@stackra/ts-container": "^2.0.10"
  },
  "devDependencies": {
    "@stackra/ts-http": "^1.0.0",
    "@stackra/eslint-config": "^1.0.6",
    "@stackra/prettier-config": "^1.0.3",
    "@stackra/tsup-config": "^1.0.3",
    "@stackra/typescript-config": "^1.0.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "eslint": "10.2.1",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-native": "^0.79.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@stackra/ts-container": "^2.0.10",
    "@stackra/ts-http": "^1.0.0",
    "react": "^19.2.5",
    "react-native": ">=0.72.0",
    "@react-navigation/native": ">=6.0.0",
    "react-native-fbsdk-next": ">=13.0.0",
    "@react-native-firebase/analytics": ">=18.0.0",
    "react-native-tracking-transparency": ">=0.1.0",
    "react-native-idfa-aaid": ">=0.1.0",
    "reflect-metadata": "^0.2.2",
    "@react-native-community/netinfo": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "@stackra/ts-container": {
      "optional": false
    },
    "@stackra/ts-http": {
      "optional": false
    },
    "reflect-metadata": {
      "optional": false
    },
    "react-native": {
      "optional": false
    },
    "@react-navigation/native": {
      "optional": true
    },
    "react-native-fbsdk-next": {
      "optional": true
    },
    "@react-native-firebase/analytics": {
      "optional": true
    },
    "react-native-tracking-transparency": {
      "optional": true
    },
    "react-native-idfa-aaid": {
      "optional": true
    },
    "@react-native-community/netinfo": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "packageManager": "pnpm@10.33.2"
}
