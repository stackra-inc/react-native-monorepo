# =============================================================================
# pnpm Configuration — react-native-monorepo
# =============================================================================
#
# node-linker=hoisted creates a flat node_modules structure identical to npm.
# Required for React Native + Expo + Metro in a pnpm monorepo because:
#   - Metro follows symlinks into .pnpm store and triggers "Unexpectedly
#     escaped traversal" errors when resolving transitive dependencies
#   - shamefully-hoist=true still uses pnpm's symlink structure internally
#   - node-linker=hoisted completely eliminates symlinks, making Metro
#     resolve packages the same way as npm/yarn
#   - Expo plugins, CocoaPods, and Gradle all expect flat node_modules
#
# Trade-off: loses pnpm's strict dependency isolation, but gains full
# compatibility with React Native's toolchain.
#
# See: https://pnpm.io/npmrc#node-linker
# =============================================================================

node-linker=hoisted

# Allow postinstall scripts for packages that need native compilation.
# Required by Uniwind Pro to download and install the native C++ engine.
enable-pre-post-scripts=true
