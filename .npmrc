# =============================================================================
# pnpm Configuration — react-native-monorepo
# =============================================================================
#
# shamefully-hoist=true flattens all packages to root node_modules.
# Required for React Native + Expo in a pnpm monorepo because:
#   - Metro bundler resolves modules by walking up the directory tree
#   - Expo plugins (expo-font, expo-splash-screen) need to be findable
#     from the app directory without following pnpm symlinks
#   - Native CocoaPods/Gradle builds resolve JS modules from node_modules
#   - Transitive deps (invariant, hoist-non-react-statics, culori, etc.)
#     must be accessible without explicit installation
#
# Without this, you get "Unable to resolve module" errors at runtime.
# =============================================================================

shamefully-hoist=true
