{
  "name": "@stackra/kbd",
  "version": "1.0.0",
  "private": false,
  "description": "Stackra Kbd component integration with HeroUI, providing keyboard shortcut display utilities for enhanced UI documentation and user guidance.",
  "repository": {
    "type": "git",
    "url": "https://github.com/stackra-inc/stackra-inc.git",
    "directory": "packages/kbd"
  },
  "license": "MIT",
  "author": "stackra-inc",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "attw": "attw --pack .",
    "build": "tsup",
    "dev": "tsup --watch",
    "publint": "publint --strict=true --level=suggestion",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "test:ui": "vitest --ui",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "clean": "rm -rf dist node_modules/.cache",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "prepublishOnly": "pnpm run build",
    "release": "pnpm publish --access public --no-git-checks"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@esbuild-plugins/node-resolve": "^0.2.2",
    "@nesvel/eslint-config": "^1.0.5",
    "@nesvel/prettier-config": "^1.0.3",
    "@nesvel/tsup-config": "^1.0.3",
    "@nesvel/typescript-config": "^1.0.4",
    "@refinedev/core": "^5.0.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.2",
    "happy-dom": "^20.8.9",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "eslint": "10.2.0",
    "typescript-eslint": "^8.58.0",
    "@storybook/react": "^10.3.3"
  },
  "peerDependencies": {
    "@heroui/react": "^3.0.0",
    "@stackra/ts-container": "^2.0.4",
    "@refinedev/core": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "@stackra/ts-support": "workspace:*",
    "lucide-react": "^1.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependenciesMeta": {
    "@stackra/ts-container": {
      "optional": false
    },
    "@stackra/ts-support": {
      "optional": false
    },
    "@heroui/react": {
      "optional": false
    },
    "@refinedev/core": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.33.0"
}
