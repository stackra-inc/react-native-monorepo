# =============================================================================
# .gitignore — react-native-monorepo
# =============================================================================

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build Outputs ────────────────────────────────────────────────────────────
dist/
build/
.next/
.swc/
out/

# ── Testing ──────────────────────────────────────────────────────────────────
coverage/

# ── Expo / React Native ─────────────────────────────────────────────────────
.expo/
.expo-shared/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/

# ── Native Builds (regenerated by expo prebuild) ────────────────────────────
# Uncomment if you want to gitignore native dirs (recommended for managed workflow)
# ios/
# android/

# ── Turbo ────────────────────────────────────────────────────────────────────
.turbo/

# ── Environment ──────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Debug Logs ───────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ── OS Files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem

# ── IDE ──────────────────────────────────────────────────────────────────────
.idea/
*.swp
*.swo

# ── Misc ─────────────────────────────────────────────────────────────────────
*.tsbuildinfo
.cache/
dependency-graph.html

# ── Reference Docs (external package copies) ─────────────────────────────────
.docs/
