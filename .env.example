# =============================================================================
# Environment Variables — React Native Monorepo
# =============================================================================
#
# Copy this file to `.env.development`, `.env.preview`, or `.env.production`
# inside `apps/native/` and fill in the values for your environment.
#
# Variables prefixed with EXPO_PUBLIC_ are inlined at build time and
# accessible in client code. All others are server-side / CI only.
#
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────

# Display name shown in the app (e.g. "HeroUI Native" or "HeroUI Native (Dev)")
EXPO_PUBLIC_APP_NAME=HeroUI Native

# Current environment: development | preview | production
EXPO_PUBLIC_APP_ENV=development

# ── API ──────────────────────────────────────────────────────────────────────

# Base URL for the backend API (no trailing slash)
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# API request timeout in milliseconds
EXPO_PUBLIC_API_TIMEOUT=30000

# ── Expo / EAS ───────────────────────────────────────────────────────────────

# Expo project ID from https://expo.dev — replaces YOUR_PROJECT_ID in app.json
EXPO_PROJECT_ID=

# Expo account owner — replaces YOUR_EXPO_OWNER in app.json
EXPO_OWNER=

# ── Sentry ───────────────────────────────────────────────────────────────────

# Sentry DSN for error tracking (get from sentry.io → Project Settings → DSN)
EXPO_PUBLIC_SENTRY_DSN=

# Auth token for source map uploads during CI builds (sentry.io → Settings → Auth Tokens)
SENTRY_AUTH_TOKEN=

# Sentry organization slug (sentry.io → Settings → General)
SENTRY_ORG=

# Sentry project slug (sentry.io → Settings → Projects)
SENTRY_PROJECT=

# ── Observability ────────────────────────────────────────────────────────────

# Enable analytics / telemetry collection (true | false)
EXPO_PUBLIC_ANALYTICS_ENABLED=false

# Minimum log level: debug | info | warn | error | silent
EXPO_PUBLIC_LOG_LEVEL=debug

# ── CI / CD ──────────────────────────────────────────────────────────────────

# Expo token for CI authentication (expo.dev → Access Tokens)
# Used by GitHub Actions to run eas build / eas submit
EXPO_TOKEN=

# Turborepo remote cache token (vercel.com → Turbo → Tokens)
TURBO_TOKEN=

# Turborepo team slug for remote caching
TURBO_TEAM=
