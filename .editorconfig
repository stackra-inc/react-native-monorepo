# .editorconfig — frontend-monorepo
#
# Ensures consistent coding style across all editors and IDEs.
# See https://editorconfig.org

root = true

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# ---------------------------------------------------------------------------
# JavaScript / TypeScript / JSON
# ---------------------------------------------------------------------------
[*.{js,jsx,ts,tsx,json,jsonc}]
indent_size = 2

# ---------------------------------------------------------------------------
# YAML
# ---------------------------------------------------------------------------
[*.{yml,yaml}]
indent_size = 2

# ---------------------------------------------------------------------------
# CSS / SCSS
# ---------------------------------------------------------------------------
[*.{css,scss,sass}]
indent_size = 2

# ---------------------------------------------------------------------------
# Markdown — preserve trailing whitespace (two spaces = line break)
# ---------------------------------------------------------------------------
[*.md]
trim_trailing_whitespace = false

# ---------------------------------------------------------------------------
# Makefiles — must use tabs
# ---------------------------------------------------------------------------
[Makefile]
indent_style = tab
